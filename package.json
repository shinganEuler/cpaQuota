{
  "name": "cpa-quota-status-bar",
  "displayName": "CPA Quota Status Bar",
  "description": "Show Codex, Gemini CLI, and Claude Code quotas from CPA Manager Plus in the VS Code status bar",
  "version": "0.1.2",
  "publisher": "shinganeuler",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinganEuler/cpaQuota.git"
  },
  "bugs": {
    "url": "https://github.com/shinganEuler/cpaQuota/issues"
  },
  "homepage": "https://github.com/shinganEuler/cpaQuota",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "cpa",
    "quota",
    "cpa-manager-plus",
    "codex",
    "gemini",
    "claude",
    "statusbar",
    "配额"
  ],
  "galleryBanner": {
    "color": "#0c141d",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:cpaQuota.refresh"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cpaQuota.refresh",
        "title": "CPA Quota: Refresh Quotas",
        "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "CPA Quota",
      "properties": {
        "cpaQuota.managerBaseUrl": {
          "type": "string",
          "default": "http://localhost:8317",
          "description": "CPA Manager Plus or CPA Management API base URL, for example http://localhost:8317."
        },
        "cpaQuota.managementKey": {
          "type": "string",
          "default": "",
          "description": "CPA Manager Plus admin key or CPA Management Key. It is sent as Bearer and X-Management-Key headers."
        },
        "cpaQuota.providerVisibility": {
          "type": "object",
          "default": {
            "codex": true,
            "gemini": true,
            "claude": true
          },
          "properties": {
            "codex": {
              "type": "boolean",
              "default": true,
              "description": "Show Codex quota."
            },
            "gemini": {
              "type": "boolean",
              "default": true,
              "description": "Show Gemini CLI quota."
            },
            "claude": {
              "type": "boolean",
              "default": true,
              "description": "Show Claude Code quota."
            }
          },
          "description": "Providers shown in the status bar."
        },
        "cpaQuota.interval": {
          "type": "number",
          "default": 60,
          "minimum": 1,
          "description": "Quota refresh interval in minutes. The default is 60 minutes and the minimum is 1 minute."
        },
        "cpaQuota.hideStatusBar": {
          "type": "boolean",
          "default": false,
          "description": "Hide the CPA quota status bar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node ./test/quotaService.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "1.74.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ]
}
